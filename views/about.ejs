<%- include('partials/head', { title }) %>
<%- include('partials/nav', { currentPath: '/about' }) %>

<main class="page-text">
  <article class="about">
    <h1 class="about__name">Bolivar Barrios</h1>
    <p class="about__role"><%= t.about.role %></p>

    <div class="about__bio">
      <% t.about.bioParagraphs.forEach((para, i) => { %>
        <% if (i < t.about.bioParagraphs.length - 1) { %>
          <p><%= para %></p>
        <% } else { %>
          <p><%= para %></p>
          <p><a href="/contact" class="about__cta"><%= t.about.cta %></a></p>
        <% } %>
      <% }) %>
    </div>

    <div class="about__gear">
      <h2 class="about__gear-title"><%= t.about.gear %></h2>
      <ul class="about__gear-list">
        <li>Sony α6700</li>
        <li>iPhone 16 Pro Max</li>
        <li>Insta360 X4</li>
      </ul>
    </div>
  </article>
</main>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Bolivar Barrios Fotografía",
  "description": "Bolivar Barrios — fotógrafo en Ciudad de Panamá. Retrato, paisaje, calle y naturaleza. Más de siete años capturando lo que pasa desapercibido.",
  "url": "https://bolivarbarrios.work",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ciudad de Panamá",
    "addressCountry": "PA"
  },
  "priceRange": "$$",
  "founder": { "@type": "Person", "name": "Bolivar Barrios" },
  "knowsAbout": ["Fotografía de retrato", "Fotografía de paisaje", "Fotografía de calle", "Fotografía de viajes", "Fotografía de naturaleza"]
}
</script>

<%- include('partials/footer') %>
