<%- include('../partials/head', { title, bodyClass: 'admin-body' }) %>
<%- include('../partials/admin-nav') %>

<main class="admin-main">
  <h1 class="admin-page-title">Dashboard</h1>

  <div class="stats-grid">
    <div class="stat-card">
      <span class="stat-card__number"><%= photoCount %></span>
      <span class="stat-card__label"><%= t.admin.dashboard.photos %></span>
    </div>
    <div class="stat-card">
      <span class="stat-card__number"><%= collectionCount %></span>
      <span class="stat-card__label"><%= t.admin.dashboard.collections %></span>
    </div>
    <div class="stat-card<%= unreadCount > 0 ? ' stat-card--alert' : '' %>">
      <span class="stat-card__number"><%= unreadCount %></span>
      <span class="stat-card__label"><%= t.admin.dashboard.unread %></span>
    </div>
  </div>

  <div class="dashboard-actions">
    <a href="/admin/photos/upload" class="btn btn--primary"><%= t.admin.dashboard.uploadPhotos %></a>
    <a href="/admin/submissions" class="btn btn--ghost"><%= t.admin.dashboard.viewMessages %></a>
    <a href="/" class="btn btn--ghost" target="_blank"><%= t.admin.dashboard.viewSite %></a>
  </div>
</main>

<script type="module" src="/dist/admin.js"></script>
</body>
</html>
