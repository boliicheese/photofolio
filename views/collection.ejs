<%- include('partials/head', { title }) %>
<%- include('partials/nav', { currentPath: '/collections' }) %>

<main class="page-gallery">
  <div class="page-gallery__header">
    <a href="/collections" class="back-link"><%= t.collection.back %></a>
    <h1 class="page-gallery__title"><%= collection.name %></h1>
    <% if (collection.description) { %>
      <p class="page-gallery__desc"><%= collection.description %></p>
    <% } %>
  </div>

  <% if (photos.length === 0) { %>
    <div class="empty-state"><p><%= t.collection.empty %></p></div>
  <% } else { %>
    <div class="gallery-grid" id="gallery-grid" data-view-photo-label="<%= t.gallery.viewPhoto %>">
      <% photos.forEach((photo, i) => { %>
        <button
          class="gallery-item"
          data-index="<%= i %>"
          aria-label="<%= photo.title || t.gallery.viewPhoto %>"
          style="--ar-ratio: <%= photo.originalHeight && photo.originalWidth ? photo.originalWidth + '/' + photo.originalHeight : '3/2' %>"
        >
          <img
            class="gallery-item__img"
            src="<%= photo.thumbUrl %>"
            alt="<%= photo.title || '' %>"
            loading="<%= i === 0 ? 'eager' : 'lazy' %>"
            fetchpriority="<%= i === 0 ? 'high' : 'auto' %>"
            decoding="async"
            draggable="false"
          >
        </button>
      <% }) %>
    </div>
  <% } %>
</main>

<script type="application/json" id="gallery-data">
<%- JSON.stringify(photos.map(p => ({
  id:             p.id,
  title:          p.title,
  location:       p.location,
  shotAt:         p.shotAt,
  fullUrl:        p.fullUrl,
  originalWidth:  p.originalWidth,
  originalHeight: p.originalHeight,
}))).replace(/</g, '\\u003c') %>
</script>

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "name": collection.name + " — Bolivar Barrios",
  "description": collection.description || ("Colección " + collection.name + " — Bolivar Barrios"),
  "url": "https://bolivarbarrios.work/collections/" + collection.slug,
  "author": { "@type": "Person", "name": "Bolivar Barrios" },
  "image": photos.map(p => Object.assign(
    {
      "@type": "ImageObject",
      "contentUrl": p.fullUrl,
      "name": p.title || "Fotografía de Bolivar Barrios",
      "creator": { "@type": "Person", "name": "Bolivar Barrios" },
      "copyrightHolder": { "@type": "Person", "name": "Bolivar Barrios" },
    },
    p.location ? { "contentLocation": p.location } : {},
    p.shotAt   ? { "dateCreated": p.shotAt }        : {}
  ))
}).replace(/</g, '\\u003c') %>
</script>

<%- include('partials/footer') %>
