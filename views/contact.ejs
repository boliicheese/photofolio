<%- include('partials/head', { title }) %>
<%- include('partials/nav', { currentPath: '/contact' }) %>

<main class="page-text">
  <div class="contact-wrap">
    <h1 class="page-title"><%= t.contact.title %></h1>

    <% if (success) { %>
      <div class="alert alert--success">
        <p><%= t.contact.success %></p>
      </div>
    <% } else { %>
      <% if (error) { %>
        <div class="alert alert--error"><p><%= error %></p></div>
      <% } %>

      <form class="contact-form" method="POST" action="/contact" novalidate>
        <div class="contact-form__hp" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
        </div>

        <div class="form-group">
          <label class="form-label" for="name"><%= t.contact.name %></label>
          <input
            class="form-input"
            type="text"
            id="name"
            name="name"
            value="<%= formData.name || '' %>"
            required
            autocomplete="name"
          >
        </div>

        <div class="form-group">
          <label class="form-label" for="email"><%= t.contact.email %></label>
          <input
            class="form-input"
            type="email"
            id="email"
            name="email"
            value="<%= formData.email || '' %>"
            required
            autocomplete="email"
          >
        </div>

        <div class="form-group">
          <label class="form-label" for="message"><%= t.contact.message %></label>
          <textarea
            class="form-input form-textarea"
            id="message"
            name="message"
            rows="6"
            required
          ><%= formData.message || '' %></textarea>
        </div>

        <button class="btn btn--primary" type="submit"><%= t.contact.send %></button>
      </form>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
