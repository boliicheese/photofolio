<%- include('partials/head', { title }) %>
<%- include('partials/nav', { currentPath: '/gallery' }) %>

<main class="page-gallery">
  <% if (photos.length === 0) { %>
    <div class="empty-state">
      <p><%= t.gallery.empty %></p>
    </div>
  <% } else { %>
    <div class="gallery-grid" id="gallery-grid" data-view-photo-label="<%= t.gallery.viewPhoto %>">
      <% photos.forEach((photo, i) => { %>
        <button
          class="gallery-item"
          data-index="<%= i %>"
          aria-label="<%= photo.title || t.gallery.viewPhoto %>"
          style="--ar-ratio: <%= photo.originalHeight && photo.originalWidth ? photo.originalWidth + '/' + photo.originalHeight : '3/2' %>"
        >
          <img
            class="gallery-item__img"
            src="<%= photo.thumbUrl %>"
            alt="<%= photo.title || '' %>"
            loading="lazy"
            draggable="false"
          >
        </button>
      <% }) %>
    </div>

    <% if (hasMore) { %>
      <div class="gallery-more" id="gallery-more">
        <button
          class="btn btn--ghost"
          id="load-more-btn"
          data-offset="<%= photos.length %>"
          data-label="<%= t.gallery.loadMore %>"
          data-loading="<%= t.gallery.loading %>"
        ><%= t.gallery.loadMore %></button>
      </div>
    <% } %>
  <% } %>
</main>

<script type="application/json" id="gallery-data">
<%- JSON.stringify(photos.map(p => ({
  id:             p.id,
  title:          p.title,
  location:       p.location,
  shotAt:         p.shotAt,
  fullUrl:        p.fullUrl,
  originalWidth:  p.originalWidth,
  originalHeight: p.originalHeight,
}))).replace(/</g, '\\u003c') %>
</script>

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "name": "Galería — Bolivar Barrios",
  "description": "Fotografías de retrato, paisaje, calle y naturaleza desde Panamá.",
  "url": "https://bolivarbarrios.work/gallery",
  "author": { "@type": "Person", "name": "Bolivar Barrios" },
  "image": photos.map(p => Object.assign(
    {
      "@type": "ImageObject",
      "contentUrl": p.fullUrl,
      "name": p.title || "Fotografía de Bolivar Barrios",
      "creator": { "@type": "Person", "name": "Bolivar Barrios" },
      "copyrightHolder": { "@type": "Person", "name": "Bolivar Barrios" },
    },
    p.location ? { "contentLocation": p.location } : {},
    p.shotAt   ? { "dateCreated": p.shotAt }        : {}
  ))
}).replace(/</g, '\\u003c') %>
</script>

<%- include('partials/footer') %>
