<header class="nav nav--admin" id="admin-nav">
  <a class="nav__logo" href="/admin">BB</a>
  <nav class="nav__links" id="admin-nav-links">
    <a href="/admin/photos" class="nav__link<%= currentPath?.startsWith('/admin/photos') ? ' nav__link--active' : '' %>"><%= t.admin.nav.photos %></a>
    <a href="/admin/photos/upload" class="nav__link<%= currentPath === '/admin/photos/upload' ? ' nav__link--active' : '' %>"><%= t.admin.nav.upload %></a>
    <a href="/admin/collections" class="nav__link<%= currentPath === '/admin/collections' ? ' nav__link--active' : '' %>"><%= t.admin.nav.collections %></a>
    <a href="/admin/submissions" class="nav__link<%= currentPath === '/admin/submissions' ? ' nav__link--active' : '' %>">
      <%= t.admin.nav.messages %>
      <% if (unreadCount > 0) { %><span class="nav__badge" id="unread-badge"><%= unreadCount %></span><% } %>
    </a>
    <a href="/admin/carousel" class="nav__link<%= currentPath === '/admin/carousel' ? ' nav__link--active' : '' %>"><%= t.admin.nav.carousel %></a>
    <a href="/lang/<%= lang === 'es' ? 'en' : 'es' %>" class="nav__link nav__lang-toggle"><%= lang === 'es' ? 'EN' : 'ES' %></a>
    <form method="POST" action="/admin/logout" class="nav__logout-form">
      <button type="submit" class="nav__link nav__link-btn"><%= t.admin.nav.logout %></button>
    </form>
  </nav>
  <button class="nav__burger" id="admin-nav-burger" aria-label="Menu" aria-expanded="false">
    <span class="nav__burger-line"></span>
    <span class="nav__burger-line"></span>
    <span class="nav__burger-line"></span>
  </button>
</header>
