<header class="nav<%= typeof heroNav !== 'undefined' && heroNav ? ' nav--hero' : '' %>" id="site-nav">
  <a class="nav__logo" href="/">BB</a>
  <nav class="nav__links" id="nav-links">
    <a href="/gallery" class="nav__link<%= currentPath === '/gallery' ? ' nav__link--active' : '' %>"><%= t.nav.gallery %></a>
    <a href="/collections" class="nav__link<%= currentPath === '/collections' ? ' nav__link--active' : '' %>"><%= t.nav.collections %></a>
    <a href="/about" class="nav__link<%= currentPath === '/about' ? ' nav__link--active' : '' %>"><%= t.nav.about %></a>
    <a href="/contact" class="nav__link<%= currentPath === '/contact' ? ' nav__link--active' : '' %>"><%= t.nav.contact %></a>
    <a href="/lang/<%= lang === 'es' ? 'en' : 'es' %>" class="nav__link nav__lang-toggle"><%= lang === 'es' ? 'EN' : 'ES' %></a>
  </nav>
  <button class="nav__burger" id="nav-burger" aria-label="Menu" aria-expanded="false">
    <span class="nav__burger-line"></span>
    <span class="nav__burger-line"></span>
    <span class="nav__burger-line"></span>
  </button>
</header>
